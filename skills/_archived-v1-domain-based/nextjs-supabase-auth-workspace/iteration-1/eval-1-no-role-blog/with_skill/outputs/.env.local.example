# Supabase 프로젝트 설정 > API 에서 확인.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role 키는 이 0-role 블로그 시나리오에서는 사용하지 않는다.
# (RLS를 우회해야 할 시스템 작업이 없음 — SUMMARY.md 참고)
# 나중에 필요해지면 SUPABASE_SERVICE_ROLE_KEY를 추가하고,
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 않는다.
