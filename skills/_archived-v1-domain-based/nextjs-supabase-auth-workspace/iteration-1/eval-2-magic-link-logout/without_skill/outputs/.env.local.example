# Public - safe to expose to the browser (anon key is rate-limited & RLS-scoped)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Server-only secret. Never prefix with NEXT_PUBLIC_, never import in
# client components. Only needed if you use admin/service-role operations
# elsewhere in the app - not required by the auth flows in this folder.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
