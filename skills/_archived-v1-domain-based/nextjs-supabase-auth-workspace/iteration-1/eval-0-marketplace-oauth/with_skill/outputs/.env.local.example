# .env.local.example
# Copy to .env.local and fill in real values. Never commit the real file.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Server-only. Bypasses RLS entirely — keep out of any NEXT_PUBLIC_ var,
# out of client bundles, and out of source control / CI logs.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Configure in Google Cloud Console (OAuth client) and mirror in
# Supabase Dashboard > Authentication > Providers > Google.
# Authorized redirect URI must be:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
