# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Used to build absolute redirect URLs (email confirmation, OAuth, etc.)
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: set this to your deployed domain, e.g.
# NEXT_PUBLIC_SITE_URL=https://your-marketplace.com

# Server-only — NEVER prefix with NEXT_PUBLIC_. Only needed if you add
# admin-only server code (e.g. service-role scripts, webhooks). Not used by
# the auth flow itself, included here for completeness.
# SUPABASE_SERVICE_ROLE_KEY=
