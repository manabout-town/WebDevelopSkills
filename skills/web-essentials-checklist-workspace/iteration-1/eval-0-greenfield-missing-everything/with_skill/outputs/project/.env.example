# Public Supabase project config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production site URL, used by app/robots.ts and app/sitemap.ts
NEXT_PUBLIC_SITE_URL=

# Server-only. Never commit a real value or log it. Only needed if you add
# server-side logic that must bypass RLS — this skill's auth floor doesn't use it.
SUPABASE_SERVICE_ROLE_KEY=
