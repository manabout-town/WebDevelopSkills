# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already in .gitignore.

# Supabase project URL and anon (public) key.
# Find these in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only required for server-side admin/privileged operations.
# NEVER prefix this with NEXT_PUBLIC_ and never expose it to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL, used to build absolute URLs for metadata, sitemap,
# robots.txt and Open Graph tags. Set this to your real production
# domain when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
