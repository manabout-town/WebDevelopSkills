# Copy this file to .env.local and fill in the values from your Supabase project settings.
# Required at build/runtime - validated by lib/env.ts.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional - used for absolute URLs in robots.txt, sitemap.xml, and Open Graph metadata.
# Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
