# Public (safe to expose to the browser) — Supabase project URL and anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets — NEVER prefix with NEXT_PUBLIC_, never commit real
# values, never put them in scripts. Set these in your hosting provider's
# environment variable settings (e.g. Vercel Project Settings).
SUPABASE_SERVICE_ROLE_KEY=
TOSS_SECRET_KEY=
